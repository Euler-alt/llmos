{
  "window": "HeapPromptWindow",
  "description": "管理全局键值存储，用于保存需要持久化或跨帧访问的数据。",
  "call_type": "prompt",
  "functions": [
    {
      "name": "heap_set",
      "description": "设置堆中指定 key 的值。",
      "parameters": {
        "key": "string (必选)",
        "value": "any JSON-serializable (必选)"
      }
    },
    {
      "name": "heap_delete",
      "description": "删除堆中指定 key。",
      "parameters": {
        "key": "string (必选)"
      }
    }
  ]
}